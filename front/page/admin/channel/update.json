{
  "page": {
    "name": "频道编辑",
    "parent": "source/channel/manage",
    "type": 2,
    "auth": [
      {
        "key": "source/channel/create",
        "name": "频道新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "source/channel/update",
        "name": "频道编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：官方资源",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "频道名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "sort": 100,
      "status": 1
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form",
      "data": {
        "id": "$form.id",
        "name": "$form.name"
      },
      "before": {
        "type": "service",
        "use": "source.SourceHook.BeforeSaveChannel"
      }
    }
  }
}
