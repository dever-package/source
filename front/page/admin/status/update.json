{
  "page": {
    "name": "状态编辑",
    "parent": "source/status/list",
    "type": 2,
    "auth": [
      {
        "key": "source/status/create",
        "name": "状态新增",
        "query": {
          "id": "empty"
        }
      },
      {
        "key": "source/status/update",
        "name": "状态编辑",
        "query": {
          "id": "required"
        }
      }
    ]
  },
  "layout": {
    "type": "container",
    "children": {
      "page-main": {
        "type": "main",
        "className": "p-0",
        "children": {
          "dialog-shell": {
            "type": "container",
            "className": "w-full"
          }
        }
      }
    }
  },
  "nodes": {
    "dialog-shell": [
      {
        "type": "form-input",
        "placeholder": "例如：上架、下架、待确认",
        "value": "form.name",
        "mode": "form",
        "validate": [
          {
            "type": "required",
            "message": "状态名称不能为空。"
          }
        ],
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-input",
        "placeholder": "例如：#0f766e",
        "value": "form.color",
        "mode": "form",
        "info": "用于列表标签展示，填写十六进制颜色值。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[180px]"
        }
      },
      {
        "type": "form-radio",
        "value": "form.online",
        "mode": "form",
        "option": "option.online",
        "info": "可展示表示该状态的资源允许在业务端展示或参与 AI 生成前校验。",
        "meta": {
          "formLayout": "horizontal"
        }
      },
      {
        "type": "form-number",
        "value": "form.sort",
        "mode": "form",
        "info": "正序排序，数值越小越靠前。",
        "meta": {
          "formLayout": "horizontal",
          "controlClassName": "max-w-[160px]"
        }
      }
    ]
  },
  "data": {
    "form": {
      "id": "",
      "name": "",
      "color": "",
      "online": 1,
      "status": 1,
      "sort": 100
    }
  },
  "state": {},
  "action": {
    "submit": {
      "type": "save",
      "params": "form"
    }
  }
}
