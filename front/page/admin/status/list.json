{
  "page": {
    "name": "状态管理",
    "icon": "list-checks",
    "parent": "source-config",
    "sort": 4
  },
  "layout": {
    "type": "container",
    "children": {
      "page-header": {
        "type": "header",
        "className": "gap-4",
        "children": {
          "header-actions": {
            "type": "row",
            "className": "ms-auto shrink-0 flex-nowrap items-center gap-2"
          }
        }
      },
      "page-main": {
        "type": "main",
        "className": "flex flex-1 flex-col gap-5 sm:gap-6",
        "children": {
          "toolbar-row": {
            "type": "row",
            "className": "flex-wrap items-center gap-2.5"
          },
          "table-row": {
            "type": "container",
            "className": "overflow-hidden rounded-md border bg-background"
          },
          "feedback-shell": {
            "type": "container"
          }
        }
      }
    }
  },
  "nodes": {
    "page-header": [
      {
        "type": "show-title",
        "value": "page",
        "className": "min-w-0 flex-1"
      }
    ],
    "header-actions": [
      {
        "type": "show-button",
        "name": "新增状态",
        "className": "shrink-0",
        "meta": {
          "variant": "default",
          "size": "sm",
          "icon": "plus"
        },
        "action": {
          "click": {
            "type": "modal",
            "key": "dialog.create",
            "value": true
          }
        }
      }
    ],
    "toolbar-row": [
      {
        "type": "form-input",
        "placeholder": "筛选状态名称...",
        "value": "search.keyword",
        "mode": "search"
      },
      {
        "type": "form-select",
        "placeholder": "状态",
        "value": "search.status",
        "mode": "search",
        "option": "option.status",
        "meta": {
          "controlClassName": "w-[140px]"
        }
      },
      {
        "type": "show-button",
        "name": "搜索",
        "meta": {
          "variant": "default",
          "size": "sm",
          "searchSubmit": true,
          "searchLayoutId": "toolbar-row",
          "loadingText": "搜索中..."
        }
      },
      {
        "type": "show-button",
        "name": "重置",
        "meta": {
          "variant": "outline",
          "size": "sm",
          "searchLayoutId": "toolbar-row",
          "to": "/source/status/list"
        }
      }
    ],
    "table-row": [
      {
        "type": "show-table",
        "value": "table.list",
        "meta": {
          "pagePath": "data.table.page",
          "pageSizePath": "data.table.pageSize",
          "totalPath": "data.table.total",
          "remote": true,
          "externalPagination": true,
          "savePath": "source/status/update",
          "rowKey": "id",
          "columns": [
            {
              "value": "id",
              "name": "状态ID",
              "type": "show-base",
              "className": "w-[1%] whitespace-nowrap text-center"
            },
            {
              "value": "name",
              "name": "状态名称",
              "type": "show-base"
            },
            {
              "value": "color",
              "name": "颜色",
              "type": "show-base",
              "className": "text-center"
            },
            {
              "value": "online",
              "name": "可展示",
              "type": "show-tag"
            },
            {
              "value": "status",
              "name": "状态",
              "type": "form-switch",
              "action": {
                "change": {
                  "type": "save",
                  "path": "source/status/update",
                  "params": {
                    "_partial": true,
                    "id": "$row.id",
                    "status": "$value"
                  }
                }
              },
              "meta": {
                "trueValue": 1,
                "falseValue": 2
              }
            },
            {
              "value": "sort",
              "name": "排序",
              "type": "show-base",
              "editor": "form-number",
              "trigger": "doubleClick",
              "tip": "正序排序，数值越小越靠前。"
            },
            {
              "value": "created_at",
              "name": "创建时间",
              "type": "show-date"
            },
            {
              "name": "操作",
              "type": "show-button",
              "className": "w-[1%] whitespace-nowrap px-3 text-center",
              "meta": {
                "buttons": [
                  {
                    "icon": "square-pen",
                    "variant": "outline",
                    "size": "sm",
                    "description": "编辑状态",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.editId",
                          "value": "$row.id"
                        },
                        {
                          "type": "modal",
                          "key": "dialog.edit",
                          "value": true
                        }
                      ]
                    }
                  },
                  {
                    "icon": "trash-2",
                    "variant": "outline",
                    "size": "sm",
                    "description": "删除状态",
                    "className": "text-destructive hover:text-destructive",
                    "action": {
                      "click": [
                        {
                          "type": "data",
                          "key": "actionTarget.deleteStatus",
                          "value": "$row"
                        },
                        {
                          "type": "modal",
                          "key": "confirm.delete",
                          "value": true
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "type": "show-page"
      }
    ],
    "feedback-shell": [
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.create",
          "pageRoute": "/source/status/update",
          "title": "新增状态",
          "description": "维护资源状态名称、颜色和展示规则。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "size": "lg",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-modal",
        "meta": {
          "stateKey": "dialog.edit",
          "pageRoute": "/source/status/update",
          "title": "编辑状态",
          "description": "调整资源状态名称、颜色和展示规则。",
          "footer": {
            "confirm": true,
            "confirmText": "保存"
          },
          "pageRouteQuery": {
            "id": "data.actionTarget.editId"
          },
          "size": "lg",
          "bodyClassName": "py-2"
        }
      },
      {
        "type": "feedback-confirm",
        "name": "删除状态",
        "info": "确认删除当前资源状态吗？",
        "meta": {
          "stateKey": "confirm.delete"
        },
        "action": {
          "confirm": {
            "type": "delete",
            "path": "source/status/update",
            "params": "actionTarget.deleteStatus",
            "before": {
              "service": "source.SourceHook.BeforeDeleteStatus"
            }
          }
        }
      }
    ]
  },
  "data": {
    "page": {
      "title": "状态管理",
      "description": "维护资源可选择的业务状态，资源编辑时只允许选择启用状态。"
    },
    "search": {
      "keyword": "",
      "status": ""
    },
    "table": {
      "searchFields": [
        "name"
      ],
      "filterFields": [
        "status"
      ],
      "order": "sort asc,id asc"
    },
    "actionTarget": {
      "editId": "",
      "deleteStatus": {}
    }
  },
  "state": {
    "dialog": {
      "create": false,
      "edit": false
    },
    "confirm": {
      "delete": false
    }
  },
  "action": {}
}
